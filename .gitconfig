[user]
	email = james.loveridge@ft.com
	name = James Loveridge
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBnFKvIZGZIOQjG0ALqjFmHM45sl4yuob/ekBXhJhW6V
[core]
	editor = code --wait
	excludesFile = ~/.gitignore
[alias]
	cleanup = fetch origin --prune
	branches = for-each-ref --sort=-committerdate --format=\"%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)\" refs/remotes
	who = blame
[commit]
	gpgsign = true
[gpg]
	program = /opt/homebrew/bin/gpg
	format = ssh
[pull]
	ff = only
[init]
	defaultBranch = main
[diff]
	colorMoved = default
[push]
	autoSetupRemote = true
[gpg "ssh"]
	allowedSignersFile = /Users/james.loveridge/.ssh/allowed_signers
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
