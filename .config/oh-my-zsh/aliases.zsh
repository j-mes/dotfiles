alias aliases="zsh ~/.config/oh-my-zsh/aliases.zsh"
alias cob="git checkout -b "
alias com="git checkout main"
alias exports="zsh ~/.config/oh-my-zsh/exports.zsh"
alias gap="git add -p"
alias gp="git pull"
alias gs="git status"
alias gsp="git stash pop"
alias gst="git stash -u && gs"
alias gundo="git reset HEAD~"
alias n=fnm
alias upgrade="zsh ~/.config/upgrade.zsh"
alias us="git reset HEAD ."
alias work="zsh ~/.config/oh-my-zsh/work.zsh"
alias dev="cd ~/Developer"
alias reload="source ~/.zshrc"
